from vosk import Model, KaldiRecognizer
from pydub import AudioSegment
import wave
import json
import requests
audio = AudioSegment.from_file("")
audio = audio.set_channels(1).set_frame_rate(16000)
audio.export("", format="wav")
def transcribe(filename):
    audio = AudioSegment.from_file(filename)
    audio = audio.set_channels(1).set_frame_rate(16000)
    audio.export("", format="wav")
    
    model = Model("vosk-model-small-ru-0.22")
    wf = wave.open("", "rb")
    rec = KaldiRecognizer(model, wf.getframerate())
    
    text = ""
    while True:
        data = wf.readframes(4000)
        if len(data) == 0:
            break
        if rec.AcceptWaveform(data):
            res = json.loads(rec.Result())
            text += res.get("text", "") + " "
    final = json.loads(rec.FinalResult())
    text += final.get("text", "")
    
    return text.strip()
def make_soap(transcription):
    prompt = f"Вот транскрипция приёма врача. Составь SOAP заметку ТОЛЬКО на основе того что сказано. Если информации нет — пиши 'не указано'.\n\nТранскрипция: {transcription}"
    
    response = requests.post("http://localhost:11434/api/generate", json={
        "model": "med-assistant",
        "prompt": prompt,
        "stream": False
    })
    return response.json()["response"]
filename = ""
print("Транскрибирую...")
text = transcribe(filename)
print(f"\nТранскрипция:\n{text}\n")
print("Составляю SOAP...")
soap = make_soap(text)
print(f"\nSOAP заметка:\n{soap}")
with open("result.txt", "w", encoding="utf-8") as f:
    f.write(f"Транскрипция:\n{text}\n\nSOAP:\n{soap}")
print("\nСохранено в result.txt")
