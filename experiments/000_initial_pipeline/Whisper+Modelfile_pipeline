from faster_whisper import WhisperModel
import requests
model = WhisperModel("base", device="cpu", compute_type="int8", download_root="./models")
filename = "  "
def transcribe(filename):
    segments, info = model.transcribe(filename, language="ru")
    text = ""
    for segment in segments:
        text += segment.text + " "
    print(text)
def make_soap(transcription):
    prompt = f"Вот транскрипция приёма врача. Составь SOAP заметку ТОЛЬКО на основе того что сказано. Если информации нет — пиши 'не указано'.\n\nТранскрипция: {transcription}"
    
    response = requests.post("http://localhost:11434/api/generate", json={
        "model": "med-assistant",
        "prompt": prompt,
        "stream": False
    })
    return response.json()["response"]
filename = "  "
print("Транскрибирую...")
text = transcribe(filename)
print(f"\nТранскрипция:\n{text}\n")

print("Составляю SOAP...")
soap = make_soap(text)
print(f"\nSOAP:\n{soap}")

with open("result.txt", "w", encoding="utf-8") as f:
    f.write(f"Транскрипция:\n{text}\n\nSOAP:\n{soap}")
print("\nСохранено в result.txt")
